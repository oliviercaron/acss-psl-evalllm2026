 }

\def\@talnmaketitle{\newpage
  \begin{center}
    \parindent 0pt
    \null
    \vskip 0.3cm
    {\Large\bf \@title \par}    % 17pt au lieu de 18pt
    \vskip 0.6cm
    {\large \@author \par}
    \vskip 0.4cm
  \end{center}}

