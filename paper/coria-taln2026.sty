\RequirePackage{xstring}  % Import xstring for safer string comparisons

% Define the acceptedArticle section
\newcommand{\acceptedArticle}[3][]{
  \par\vspace{0.5em}
  %\noindent\normalsize\textsc{Article :} % Keep everything inline
  %\hspace{0.1em} % Add space after "ARTICLE :"
  \IfStrEqCase{#1}{%
    {consignes}{
    \textit{\small  Lorsque l'article fait l'objet d'une double soumission et que la réponse d'acceptation est déjà connue, l'article doit être déclarée "acceptée" selon le modèle ci-dessous en précisant le nom de la conférence ou de la revue ainsi que l'url de l'article si celui-ci est connu. Lorsque l'acceptation n'est pas connue, l'article doit être déclarée "soumis" en précisant seulement le nom de la conférence ou de la revue. Ne laisser aucune indication en cas de soumission de travaux originaux.}\\
    \noindent\normalsize\textsc{Article accepté à :} #2. \\ 
            \noindent\normalsize\textsc{Url :} {\small \url{#3}} }
    {accepted}{\noindent\normalsize\textsc{Article accepté à :} #2. \\ 
            \noindent\normalsize\textsc{Url :} {\small \url{#3}} }
    {submitted}{\noindent\normalsize\textsc{Article soumis à :} #2.}
    %{original}{\textbf{Contribution originale.}}
  }[\textbf{Accepté à} ?, \textbf{Soumis à} ?]
  \par\vspace{0.2em}
  \unskip\noindent{\vskip .3em\hrule}
}

% Define the acceptedArticle section
\newcommand{\acceptedArticleold}[2][]{
  \par\vspace{0.5em}
  \noindent\normalsize\textsc{Article :} % Keep everything inline
  \hspace{0.1em} % Add space after "ARTICLE :"
  \IfStrEqCase{#1}{%
    {accepted}{\textbf{Accepté à} #2. \noindent\hspace{0.1em}  }
    {submitted}{\textbf{Soumis à} #2.}
    {original}{\textbf{Contribution originale.}}
  }[\textbf{Accepté à} ?, \textbf{Soumis à} ?, \textbf{Contribution originale ?}]
  \par\vspace{0.2em}
  \unskip\noindent{\vskip .3em\hrule}
}


