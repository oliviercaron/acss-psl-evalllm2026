# Copiez ce fichier en .env et renseignez vos valeurs (le .env est gitignoré).

# --- LLM de désambiguïsation (étape finale de la cascade) ---
# API distante (ex. OpenAI) :
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-5.4-nano
# Modèle ouvert servi localement via vLLM (alternative à l'API) :
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=gemma-4-31b
# OPENAI_API_KEY=EMPTY

# --- Options de décodage ---
# Forcer un choix contraint (guided decoding) sur les modèles qui le supportent :
LLM_GUIDED_CHOICE=0
# Budget de jetons pour les modèles à raisonnement (0 = désactivé) :
LLM_REASONING_MAXTOK=0

# --- Reproduction des runs informés par le test (run 1 et run 3) ---
# 1 = active les règles/exonymes issus de l'examen du fichier de test.
# 0 = configuration strictement généraliste (run 2).
EVALLLM_TEST_INFORMED=0
